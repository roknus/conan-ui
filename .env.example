# Copy to .env and fill in. .env is gitignored; never commit real credentials.
# This is the only configuration file — there is no config.json.

# --- Repositories -------------------------------------------------------------
# The Artifactory host, with no trailing path.
ARTIFACTORY_URL=https://your-artifactory.com

# Comma-separated Conan repository names on that host. Each remote's URL is
# derived as ${ARTIFACTORY_URL}/artifactory/api/conan/<name>, so
#   CONAN_REMOTES=conan-repo
# becomes https://your-artifactory.com/artifactory/api/conan/conan-repo
#
# The FIRST name in the list is the default remote.
CONAN_REMOTES=conan-repo,conan-dev

# --- Remote credentials -------------------------------------------------------
# Conan's own variable names, so the backend and the Conan client resolve
# credentials identically. These apply to every remote above.
CONAN_LOGIN_USERNAME=
CONAN_PASSWORD=

# Optional per-remote overrides, if a repository has its own service account.
# The remote name is upper-cased with '-' replaced by '_', and these win over
# the global vars above:
#   remote "conan-dev" -> CONAN_LOGIN_USERNAME_CONAN_DEV / CONAN_PASSWORD_CONAN_DEV
# CONAN_LOGIN_USERNAME_CONAN_DEV=
# CONAN_PASSWORD_CONAN_DEV=
